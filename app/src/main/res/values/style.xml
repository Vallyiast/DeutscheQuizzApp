<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BigText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">30sp</item>
    </style>

    <style name="ShapeAppearance.leftRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">10dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">10dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.bottomLeftRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">80dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


    <style name="ShapeAppearance.rightRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">10dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">10dp</item>
    </style>

    <style name="Button" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="backgroundTint">#1B1B1B</item>
        <item name="strokeColor">#000000</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="PrimaryButton" parent="Button">
        <item name="cornerRadius">20dp</item>
    </style>



    <style name="ButtonCharacter" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:padding">1dp</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:backgroundTint">#000000</item>
    </style>

    <style name="ButtonMenu" parent="PrimaryButton">
        <item name="android:layout_width">130dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ButtonNext" parent="PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">70dp</item>
    </style>

</resources>