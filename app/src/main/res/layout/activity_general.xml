<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="#111111"
    android:layout_height="match_parent">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:padding="12dp">

        <!-- ITEM 1 -->
        <LinearLayout
            android:id="@+id/commons"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#222222"
            android:layout_margin="6dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="TODO"
                android:src="@drawable/ic_launcher_foreground"/>

            <TextView
                android:text="Common words"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold" android:layout_height="20dp" android:layout_width="match_parent"/>
        </LinearLayout>

        <!-- ITEM 2 -->
        <LinearLayout
            android:id="@+id/chapter12"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="6dp"
            android:background="#222222">

            <TextView
                android:text="12"
                android:textSize="24sp"
                android:gravity="center_vertical"
                android:textStyle="bold"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Chapter 12"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold" android:layout_height="20dp" android:layout_width="match_parent"/>
        </LinearLayout>

        <!-- ITEM 3 -->
        <LinearLayout
            android:id="@+id/chapter13"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="6dp"
            android:background="#222222">

            <TextView
                android:text="13"
                android:textSize="24sp"
                android:gravity="center_vertical"
                android:textStyle="bold"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Practice"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold" android:layout_height="20dp" android:layout_width="match_parent"/>
        </LinearLayout>

        <!-- Add more items the same way -->
        <!-- ITEM 3 -->
        <LinearLayout

            android:id="@+id/chapter14"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="6dp"
            android:background="#222222">

            <TextView
                android:text="14"
                android:textSize="24sp"
                android:gravity="center_vertical"
                android:textStyle="bold"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Practice"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold" android:layout_height="20dp" android:layout_width="match_parent"/>
        </LinearLayout>

    </GridLayout>

</ScrollView>